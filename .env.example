# n8n webhook used by goofish-watcher to forward incoming Goofish/Xianyu messages.
N8N_WEBHOOK_URL=http://n8n:5678/webhook/goofish-inbound

# goofish-cli guard settings.
GOOFISH_WRITE_RPM=1
GOOFISH_CIRCUIT_BREAK_MINUTES=30

# Optional: local bridge settings for later stable version.
GOOFISH_BRIDGE_HOST=0.0.0.0
GOOFISH_BRIDGE_PORT=8787
MAX_REPLY_CHARS=80

# OpenClaw reply endpoint used by n8n inbound workflow.
# Default (mock mode in docker-compose.example.yml):
#   http://openclaw:18789/reply
# Real OpenClaw mode (example):
#   http://127.0.0.1:18789/reply
#   https://your-openclaw-domain/reply
# Runtime mode:
#   custom_reply -> send custom /reply payload
#   openai_chat  -> send OpenAI Chat Completions payload to /v1/chat/completions
OPENCLAW_RUNTIME_MODE=custom_reply
OPENCLAW_REPLY_URL=http://openclaw:18789/reply
OPENCLAW_CHAT_COMPLETIONS_URL=http://host.docker.internal:18789/v1/chat/completions
OPENCLAW_GATEWAY_TOKEN=replace-with-your-openclaw-gateway-token
OPENCLAW_MODEL=openclaw/default

# Optional: local runtime switch file.
# Note: safe_mode / auto_send / global_send_interval_seconds are managed in
# AUTOREPLY_STATE_FILE by goofish-bridge (/autoreply/start|stop|status).
AUTOREPLY_STATE_FILE=/app/data/autoreply-state.json
ITEMS_SNAPSHOT_PATH=/app/data/items_snapshot.json
