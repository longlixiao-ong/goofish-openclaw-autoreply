# n8n webhook used by goofish-watcher to forward incoming Goofish/Xianyu messages.
N8N_WEBHOOK_URL=http://n8n:5678/webhook/goofish-inbound

# goofish-cli guard settings.
GOOFISH_WRITE_RPM=1
GOOFISH_CIRCUIT_BREAK_MINUTES=30

# Bridge runtime settings.
GOOFISH_BRIDGE_HOST=0.0.0.0
GOOFISH_BRIDGE_PORT=8787
MAX_REPLY_CHARS=80
BRIDGE_AUTH_TOKEN=replace-with-strong-random-token

# OpenClaw / New API runtime settings.
# Only openai_chat is supported in production bridge runtime.
OPENCLAW_RUNTIME_MODE=openai_chat
OPENCLAW_CHAT_COMPLETIONS_URL=http://host.docker.internal:18789/v1/chat/completions
OPENCLAW_GATEWAY_TOKEN=replace-with-your-openclaw-gateway-token
# OPENCLAW_MODEL is an OpenAI-compatible route name exposed by OpenClaw Gateway.
# It is NOT managed by goofish-bridge and does not configure an underlying vendor model here.
OPENCLAW_MODEL=openclaw/default
OPENCLAW_TIMEOUT_SECONDS=20
HANDOFF_NOTIFY_WEBHOOK_URL=
WATCHER_FAILED_EVENTS_PATH=/app/logs/failed_events.jsonl

# Runtime state files.
AUTOREPLY_STATE_FILE=/app/data/autoreply-state.json
AUTOREPLY_RUNTIME_STATE_FILE=/app/data/autoreply-runtime-state.json
ITEMS_SNAPSHOT_PATH=/app/data/items_snapshot.json
